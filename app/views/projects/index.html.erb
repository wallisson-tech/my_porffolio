<div class="container mx-auto px-4 py-12">
  <h1 class="text-3xl font-bold text-gray-800">Projetos</h1>

  <% if @projects.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-8">
      <% @projects.each do |project| %>
        <div class="border rounded-lg p-6 shadow-md hover:shadow-lg transition-shadow">
          <h2 class="text-xl font-semibold text-gray-800"><%= project.title %></h2>
          <p class="mt-2 text-gray-600"><%= project.description %></p>
          <div class="mt-4 space-x-3">
            <% if project.github_url.present? %>
              <%= link_to "GitHub", project.github_url, class: "text-blue-600 hover:underline", target: "_blank" %>
            <% end %>
            <% if project.live_url.present? %>
              <%= link_to "Online", project.live_url, class: "text-green-600 hover:underline", target: "_blank" %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="mt-4 text-gray-500">Nenhum projeto cadastrado ainda.</p>
  <% end %>
</div>